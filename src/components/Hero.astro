---
---

<section class="hero" id="hero">

  <div class="hero__video-wrap">
    <video
      class="hero__video"
      autoplay
      muted
      loop
      playsinline
      aria-hidden="true"
    >
      <source src="/videos/hero-preview-2.mp4" type="video/mp4" />
    </video>
    <div class="hero__overlay"></div>
  </div>

  <a href="#problem" class="hero__scroll" aria-label="Scroll down">
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polyline points="6 9 12 15 18 9"></polyline>
    </svg>
  </a>

  <div class="container hero__inner">
    <div class="hero__text">
      <h1 class="hero__heading">Computer Vision for the World's Harshest Environments.<br/>From Camera to Alert.<br/>Fully Managed.</h1>
      <p class="hero__sub">
        Atlas Merlin delivers real-time AI-powered monitoring for mining and large-scale construction — from hardware to alerts, fully managed, no technical team required.
      </p>
      <a href="#contact" class="btn btn--primary hero__cta">Talk to Us</a>
    </div>
  </div>

</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    padding-top: var(--nav-height);
    padding-bottom: var(--space-md);
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  /* ---- Video background ---- */
  .hero__video-wrap {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .hero__video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Light mode: solid nav colour at top, fades to heavy wash */
  .hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(242, 240, 235, 1)    0%,
      rgba(242, 240, 235, 1)    12%,
      rgba(242, 240, 235, 0.82) 35%,
      rgba(242, 240, 235, 0.82) 100%
    );
  }

  @media (prefers-color-scheme: dark) {
    .hero__overlay {
      background: linear-gradient(
        to bottom,
        rgba(15, 26, 46, 1)    0%,
        rgba(15, 26, 46, 1)    12%,
        rgba(15, 26, 46, 0.80) 35%,
        rgba(15, 26, 46, 0.80) 100%
      );
    }
  }

  /* ---- Content ---- */
  .hero__inner {
    position: relative;
    z-index: 1;
    padding-block: var(--space-xl);
  }

  .hero__text {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-md);
    max-width: none;
  }

  .hero__heading {
    font-size: clamp(1.6rem, 2.6vw, 2.2rem);
  }

  .hero__sub {
    color: var(--text);
    max-width: 44ch;
  }

  .hero__cta {
    width: auto;
    padding: 0.875rem 2.25rem;
    font-size: 1rem;
  }

  /* ---- Scroll indicator ---- */
  .hero__scroll {
    position: absolute;
    bottom: var(--space-md);
    left: 50%;
    transform: translateX(-50%);
    z-index: 1;
    color: var(--heading);
    opacity: 0.4;
    animation: bounce 2.4s ease-in-out infinite;
    transition: opacity 150ms ease;
  }

  .hero__scroll:hover { opacity: 0.7; }

  @keyframes bounce {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  /* ---- Responsive ---- */
  @media (max-width: 768px) {
    .hero__cta {
      width: 100%;
      text-align: center;
    }

    .hero__heading {
      max-width: 100%;
    }
  }
</style>

<script>
  // Subtle parallax: video moves at ~40% scroll speed
  const wrap = document.querySelector('.hero__video-wrap') as HTMLElement;
  if (wrap) {
    window.addEventListener('scroll', () => {
      const y = window.scrollY;
      wrap.style.transform = `translateY(${y * 0.4}px)`;
    }, { passive: true });
  }

  // Slow the video playback
  const video = document.querySelector('.hero__video') as HTMLVideoElement;
  if (video) video.playbackRate = 0.5;
</script>
