---
import { readFileSync } from 'fs';
import { join } from 'path';

// Read the base SVG (dark logo — paths use #0f1a2e and #d4873f)
// We replace hardcoded fills with CSS variable references so the logo
// responds to prefers-color-scheme automatically, no JS needed.
let svg = readFileSync(
  join(process.cwd(), 'public/darklogo_for_lightbackground_desktop.svg'),
  'utf-8'
);

// Replace hardcoded colours with CSS variables
svg = svg.replace(/fill="#0f1a2e"/gi, 'fill="var(--logo-main)"');
svg = svg.replace(/fill="#d4873f"/gi, 'fill="var(--logo-diamond)"');
// Keep the hidden background rect invisible
svg = svg.replace(/fill="#f2f0eb"/gi, 'fill="none"');
---

<div class="logo">
  <Fragment set:html={svg} />
</div>

<style>
  .logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .logo :global(svg) {
    height: 64px;
    width: auto;
    display: block;
    transition: opacity 0.2s ease;
  }

  .logo:hover :global(svg) {
    opacity: 0.8;
  }

  .logo :global(#path13) {
    transform-origin: center;
    transform-box: fill-box;
  }
</style>

<script>
  const diamond = document.getElementById('path13') as SVGElement | null;
  if (diamond) {
    let scrollTimeout: ReturnType<typeof setTimeout>;

    window.addEventListener('scroll', () => {
      const rotation = window.scrollY * 0.08;

      // No transition while scrolling — keep it snappy
      diamond.style.transition = 'none';
      diamond.style.transform = `rotate(${rotation}deg)`;

      // When scrolling stops, snap to nearest diamond orientation
      clearTimeout(scrollTimeout);
      scrollTimeout = setTimeout(() => {
        const nearest = Math.round(rotation / 90) * 90;
        diamond.style.transition = 'transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1)';
        diamond.style.transform = `rotate(${nearest}deg)`;
      }, 10);
    }, { passive: true });
  }
</script>
