---
import Logo from './Logo.astro';
---

<header class="nav" id="nav">
  <div class="nav__inner container">

    <a href="#hero" aria-label="Atlas Merlin home">
      <Logo />
    </a>

    <nav class="nav__links" aria-label="Main navigation">
      <a href="#solutions"       class="nav__link">Solutions</a>
      <a href="#how-it-works"    class="nav__link">How It Works</a>
      <a href="#why-atlas-merlin"class="nav__link">Why Atlas Merlin</a>
    </nav>

    <a href="#contact" class="btn btn--outline nav__cta">Talk to Us</a>

    <button class="nav__login" id="nav-login" aria-label="Login">
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
    </button>

    <button
      class="nav__hamburger"
      id="nav-hamburger"
      aria-label="Open menu"
      aria-expanded="false"
      aria-controls="nav-mobile"
    >
      <span></span>
      <span></span>
      <span></span>
    </button>

  </div>

  <div class="nav__mobile" id="nav-mobile" aria-hidden="true">
    <a href="#solutions"        class="nav__mobile-link">Solutions</a>
    <a href="#how-it-works"     class="nav__mobile-link">How It Works</a>
    <a href="#why-atlas-merlin" class="nav__mobile-link">Why Atlas Merlin</a>
    <a href="#contact"          class="nav__mobile-link nav__mobile-cta">Talk to Us</a>
  </div>
</header>

<!-- Login modal -->
<div class="login-backdrop" id="login-backdrop" aria-hidden="true">
  <div class="login-modal" role="dialog" aria-modal="true" aria-label="Login">

    <button class="login-modal__close" id="login-close" aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="login-modal__form-wrap" id="login-form-wrap">
      <h3 class="login-modal__heading">Log In</h3>

      <form class="login-modal__form" id="login-form" novalidate>
        <div class="login-modal__field">
          <label for="login-email">Email</label>
          <input type="email" id="login-email" name="email" autocomplete="email" required />
        </div>
        <div class="login-modal__field">
          <label for="login-password">Password</label>
          <input type="password" id="login-password" name="password" autocomplete="current-password" required />
        </div>
        <button type="submit" class="login-modal__submit">Log In</button>
      </form>
    </div>

    <div class="login-modal__message" id="login-message" aria-live="polite">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <circle cx="12" cy="8" r="4"/>
        <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
      </svg>
      <p>Atlas Merlin needs to create your account before you can log in.</p>
      <p>Get in touch at <a href="mailto:hello@atlasmerlin.com">hello@atlasmerlin.com</a></p>
    </div>

  </div>
</div>

<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    background-color: transparent;
    transition: background-color 0.3s ease, box-shadow 0.25s ease;
  }

  .nav.scrolled {
    background-color: var(--nav-bg);
    box-shadow: 0 1px 0 var(--nav-border);
  }

  .nav__inner {
    display: flex;
    align-items: center;
    height: var(--nav-height);
    gap: var(--space-md);
  }

  /* ---- Links ---- */
  .nav__links {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-left: auto;
  }

  .nav__link {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--nav-text);
    opacity: 0.8;
    transition: opacity 150ms ease;
    white-space: nowrap;
  }

  .nav__link:hover { opacity: 1; }

  /* ---- CTA ---- */
  .nav__cta {
    flex-shrink: 0;
    font-size: 0.875rem;
    padding: 0.5rem 1.25rem;
    white-space: nowrap;
    width: auto;
  }

  /* ---- Login button ---- */
  .nav__login {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--nav-text);
    opacity: 0.7;
    transition: opacity 150ms ease;
    padding: 0.25rem;
  }

  .nav__login:hover { opacity: 1; }


  /* ---- Hamburger ---- */
  .nav__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    margin-left: auto;
    flex-shrink: 0;
  }

  .nav__hamburger span {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--nav-text);
    transition: transform 0.25s ease, opacity 0.25s ease;
    transform-origin: center;
  }

  .nav__hamburger[aria-expanded="true"] span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .nav__hamburger[aria-expanded="true"] span:nth-child(2) { opacity: 0; }
  .nav__hamburger[aria-expanded="true"] span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ---- Mobile menu ---- */
  .nav__mobile {
    display: none;
    flex-direction: column;
    background-color: var(--nav-bg);
    border-top: 1px solid var(--nav-border);
    padding-bottom: var(--space-sm);
  }

  .nav__mobile.open { display: flex; }

  .nav__mobile-link {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--nav-text);
    opacity: 0.7;
    padding: 0.75rem var(--space-md);
    transition: opacity 150ms ease;
  }

  .nav__mobile-link:hover { opacity: 1; }

  .nav__mobile-cta {
    margin: var(--space-sm) var(--space-md) 0;
    padding: 0.75rem var(--space-md);
    background-color: var(--electric-orange);
    color: var(--warm-white);
    opacity: 1;
    text-align: center;
    font-weight: 700;
  }

  .nav__mobile-cta:hover { background-color: #e55a0d; opacity: 1; }

  /* ---- Mobile breakpoint ---- */
  @media (max-width: 768px) {
    .nav__links, .nav__cta { display: none; }
    .nav__login { margin-left: auto; }
    .nav__hamburger { display: flex; margin-left: 0; }
  }

  /* ---- Login modal backdrop ---- */
  .login-backdrop {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 200;
  }

  .login-backdrop.open {
    display: block;
  }

  /* ---- Modal ---- */
  .login-modal {
    background-color: var(--nav-bg);
    width: 320px;
    padding: var(--space-md);
    position: fixed;
    top: var(--nav-height);
    box-shadow: 0 8px 32px rgba(15, 26, 46, 0.15);
  }

  /* Arrow pointing up toward the login button */
  .login-modal::before {
    content: '';
    position: absolute;
    top: -7px;
    right: var(--arrow-right, 16px);
    width: 14px;
    height: 14px;
    background-color: var(--nav-bg);
    transform: rotate(45deg);
    box-shadow: -2px -2px 4px rgba(15, 26, 46, 0.06);
  }

  .login-modal__close {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    color: var(--nav-text);
    opacity: 0.4;
    transition: opacity 150ms ease;
    padding: 0.25rem;
  }

  .login-modal__close:hover { opacity: 1; }

  .login-modal__heading {
    font-size: 1.4rem;
    color: var(--heading);
    margin-bottom: var(--space-md);
  }

  /* ---- Form ---- */
  .login-modal__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .login-modal__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .login-modal__field label {
    font-family: var(--font-body);
    font-size: 0.8rem;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    color: var(--text);
    opacity: 0.6;
  }

  .login-modal__field input {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--heading);
    background-color: transparent;
    border: 1px solid var(--border);
    padding: 0.7rem 1rem;
    outline: none;
    transition: border-color 150ms ease;
    width: 100%;
  }

  .login-modal__field input:focus {
    border-color: var(--copper-light);
  }

  .login-modal__submit {
    background-color: var(--electric-orange);
    color: var(--warm-white);
    font-family: var(--font-body);
    font-size: 1rem;
    font-weight: 700;
    padding: 0.8rem;
    border: none;
    cursor: pointer;
    transition: background-color 150ms ease;
    margin-top: var(--space-xs);
  }

  .login-modal__submit:hover { background-color: #e55a0d; }

  /* ---- Message state ---- */
  .login-modal__message {
    display: none;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-sm);
    padding: var(--space-sm) 0;
    color: var(--text);
  }

  .login-modal__message svg {
    color: var(--copper-light);
    opacity: 0.6;
  }

  .login-modal__message p {
    max-width: 100%;
    font-size: 0.95rem;
  }

  .login-modal__message a {
    color: var(--electric-orange);
    text-decoration: underline;
  }

  .login-modal.show-message .login-modal__form-wrap { display: none; }
  .login-modal.show-message .login-modal__message   { display: flex; }
</style>

<script>
  const nav       = document.getElementById('nav')!;
  const hamburger = document.getElementById('nav-hamburger')!;
  const mobile    = document.getElementById('nav-mobile')!;
  const loginBtn  = document.getElementById('nav-login')!;
  const backdrop  = document.getElementById('login-backdrop')!;
  const closeBtn  = document.getElementById('login-close')!;
  const loginForm = document.getElementById('login-form')!;
  const modal     = backdrop.querySelector('.login-modal')!;

  // Nav scroll behaviour
  window.addEventListener('scroll', () => {
    nav.classList.toggle('scrolled', window.scrollY > 10);
  }, { passive: true });

  if (window.scrollY > 10) nav.classList.add('scrolled');

  // Hamburger
  hamburger.addEventListener('click', () => {
    const open = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!open));
    mobile.setAttribute('aria-hidden', String(open));
    mobile.classList.toggle('open', !open);
  });

  mobile.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      hamburger.setAttribute('aria-expanded', 'false');
      mobile.setAttribute('aria-hidden', 'true');
      mobile.classList.remove('open');
    });
  });

  // Open modal
  function openModal() {
    const modalEl = modal as HTMLElement;
    const arrowEl = modal.querySelector('.login-modal::before') as HTMLElement;
    const rect = loginBtn.getBoundingClientRect();
    const modalWidth = 320;

    // Align modal's right edge with button's right edge
    let rightPos = window.innerWidth - rect.right;
    // Clamp so it doesn't go off-screen left
    const leftPos = window.innerWidth - rightPos - modalWidth;
    if (leftPos < 8) rightPos = window.innerWidth - modalWidth - 8;

    modalEl.style.right = `${rightPos}px`;

    // Position arrow to sit under the centre of the button
    const btnCentreFromModalRight = (rect.right - rightPos) - rect.width / 2;
    const arrowOffset = Math.max(8, modalWidth - btnCentreFromModalRight - 7);
    modalEl.style.setProperty('--arrow-right', `${arrowOffset}px`);

    backdrop.classList.add('open');
    backdrop.setAttribute('aria-hidden', 'false');
    modal.classList.remove('show-message');
    (loginForm as HTMLFormElement).reset();
  }

  // Close modal
  function closeModal() {
    backdrop.classList.remove('open');
    backdrop.setAttribute('aria-hidden', 'true');
  }

  loginBtn.addEventListener('click', openModal);
  closeBtn.addEventListener('click', closeModal);

  // Close on backdrop click
  backdrop.addEventListener('click', (e) => {
    if (e.target === backdrop) closeModal();
  });

  // Close on Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closeModal();
  });

  // Form submit — show message
  loginForm.addEventListener('submit', (e) => {
    e.preventDefault();
    modal.classList.add('show-message');
  });
</script>
